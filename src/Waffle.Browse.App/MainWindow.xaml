<Window x:Class="Waffle.Browse.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:docking="clr-namespace:Waffle.Browse.App.Docking"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Waffle Browse"
        MinHeight="520"
        MinWidth="860"
        Height="800"
        Width="1280"
        Icon="Assets/AppIcon.ico"
        Loaded="OnLoaded"
        Closing="OnClosing"
        Background="{DynamicResource WindowBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}"
        FontFamily="Segoe UI"
        FontSize="13">
    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource ToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0"
                      Margin="0,0,14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBox x:Name="QuickSearchBox"
                                 AutomationProperties.AutomationId="QuickSearchBox"
                                 AutomationProperties.Name="파일 및 폴더 검색"
                                 Tag="파일 및 폴더 검색"
                                 Width="400"
                                 Height="32"
                                 VerticalContentAlignment="Center"
                                 GotKeyboardFocus="OnQuickSearchGotKeyboardFocus"
                                 TextChanged="OnQuickSearchTextChanged"
                                 KeyDown="OnQuickSearchKeyDown" />
                        <Button Content="&#xE721;"
                                Style="{StaticResource ToolbarIconButtonStyle}"
                                FontFamily="Segoe MDL2 Assets"
                                AutomationProperties.AutomationId="QuickSearchButton"
                                AutomationProperties.Name="검색 실행"
                                ToolTip="검색 실행"
                                Click="OnQuickSearchClick" />
                    </StackPanel>

                    <TextBlock x:Name="StatusText"
                               AutomationProperties.AutomationId="StatusText"
                               Grid.Column="1"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource SubtleTextBrush}"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <ToggleButton x:Name="DarkModeToggle"
                                  AutomationProperties.AutomationId="DarkModeToggle"
                                  AutomationProperties.Name="다크 모드"
                                  ToolTip="다크 모드 전환"
                                  Checked="OnThemeToggleChanged"
                                  Unchecked="OnThemeToggleChanged">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Margin="0,0,7,0"
                                       VerticalAlignment="Center"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="14"
                                       Text="&#xE706;" />
                            <TextBlock VerticalAlignment="Center" Text="Dark" />
                        </StackPanel>
                    </ToggleButton>
                    <Border Background="{DynamicResource ControlBackgroundBrush}"
                            BorderBrush="{DynamicResource ControlBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="7"
                            Padding="1">
                        <StackPanel Orientation="Horizontal">
                            <Button Style="{StaticResource SegmentButtonStyle}"
                                    AutomationProperties.AutomationId="OnePanelButton"
                                    AutomationProperties.Name="단일 패널"
                                    ToolTip="단일 패널"
                                    Click="OnOnePanelClick">
                                <Viewbox Width="18" Height="18">
                                    <Path Width="20"
                                          Height="20"
                                          Data="{StaticResource LayoutSingleGeometry}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </Button>
                            <Button Style="{StaticResource SegmentButtonStyle}"
                                    AutomationProperties.AutomationId="TwoColumnButton"
                                    AutomationProperties.Name="두 열"
                                    ToolTip="두 열"
                                    Click="OnTwoColumnClick">
                                <Viewbox Width="18" Height="18">
                                    <Path Width="20"
                                          Height="20"
                                          Data="{StaticResource LayoutColumnTwoGeometry}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </Button>
                            <Button Style="{StaticResource SegmentButtonStyle}"
                                    AutomationProperties.AutomationId="TwoRowButton"
                                    AutomationProperties.Name="두 행"
                                    ToolTip="두 행"
                                    Click="OnTwoRowClick">
                                <Viewbox Width="18" Height="18">
                                    <Path Width="20"
                                          Height="20"
                                          Data="{StaticResource LayoutRowTwoGeometry}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </Button>
                            <Button Style="{StaticResource SegmentButtonStyle}"
                                    AutomationProperties.AutomationId="ThreePanelButton"
                                    AutomationProperties.Name="세 패널"
                                    ToolTip="세 패널"
                                    Click="OnThreePanelClick">
                                <Viewbox Width="18" Height="18">
                                    <Path Width="20"
                                          Height="20"
                                          Data="{StaticResource LayoutColumnTwoSplitRightGeometry}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </Button>
                            <Button Style="{StaticResource SegmentButtonStyle}"
                                    AutomationProperties.AutomationId="FourPanelButton"
                                    AutomationProperties.Name="네 패널"
                                    ToolTip="네 패널 그리드"
                                    Click="OnFourPanelClick">
                                <Viewbox Width="18" Height="18">
                                    <Path Width="20"
                                          Height="20"
                                          Data="{StaticResource LayoutCellFourGeometry}"
                                          Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type Button}}}"
                                          Stretch="Uniform" />
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="IndexStatusBar"
                AutomationProperties.AutomationId="IndexStatusBar"
                DockPanel.Dock="Bottom"
                Visibility="Collapsed"
                Background="{DynamicResource ToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="IndexStatusText"
                           AutomationProperties.AutomationId="IndexStatusText"
                           MinWidth="76"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Text="색인 대기" />
                <ProgressBar x:Name="IndexProgressBar"
                             AutomationProperties.AutomationId="IndexProgressBar"
                             Grid.Column="1"
                             Width="140"
                             Height="6"
                             Margin="10,0"
                             VerticalAlignment="Center"
                             IsIndeterminate="False" />
                <TextBlock x:Name="IndexCountText"
                           AutomationProperties.AutomationId="IndexCountText"
                           Grid.Column="2"
                           MinWidth="110"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           Text="0개 항목" />
                <TextBlock x:Name="IndexProgressText"
                           AutomationProperties.AutomationId="IndexProgressText"
                           Grid.Column="3"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SubtleTextBrush}" />

                <TextBlock x:Name="IndexDetailText"
                           AutomationProperties.AutomationId="IndexDetailText"
                           Grid.Row="1"
                           Grid.ColumnSpan="4"
                           Margin="0,3,0,0"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           FontSize="11"
                           TextTrimming="CharacterEllipsis"
                           Text="검색창을 선택하면 현재 탭 폴더를 색인합니다." />
            </Grid>
        </Border>

        <Grid x:Name="WorkspaceRoot"
              AutomationProperties.AutomationId="WorkspaceRoot"
              Margin="4,2,4,4">
            <Grid x:Name="WorkspaceGrid" />
            <docking:DockPreviewOverlay x:Name="DockPreviewOverlay" />
        </Grid>
    </DockPanel>
</Window>
