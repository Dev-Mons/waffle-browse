<Application x:Class="Waffle.Browse.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F0E7" />
        <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#FFFCF7" />
        <SolidColorBrush x:Key="PanelBorderBrush" Color="#D8CFC1" />
        <SolidColorBrush x:Key="ActivePanelBorderBrush" Color="#B86F08" />
        <SolidColorBrush x:Key="ToolbarBackgroundBrush" Color="#F0E9DE" />
        <SolidColorBrush x:Key="PanelHeaderBackgroundBrush" Color="#F7F1E8" />
        <SolidColorBrush x:Key="DividerBrush" Color="#E7DFD4" />
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#756D62" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#25211D" />
        <SolidColorBrush x:Key="ControlBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="ControlBorderBrush" Color="#D8CFC1" />
        <SolidColorBrush x:Key="ControlForegroundBrush" Color="#25211D" />
        <SolidColorBrush x:Key="ControlHoverBackgroundBrush" Color="#F4ECDF" />
        <SolidColorBrush x:Key="ControlPressedBackgroundBrush" Color="#EADCC8" />
        <SolidColorBrush x:Key="TabHoverBackgroundBrush" Color="#F4ECDF" />
        <SolidColorBrush x:Key="TabSelectedBackgroundBrush" Color="#F8E6B8" />
        <SolidColorBrush x:Key="TabSelectedForegroundBrush" Color="#5A3505" />
        <SolidColorBrush x:Key="ShellHostBackgroundBrush" Color="#FFFFFF" />
        <SolidColorBrush x:Key="DockPreviewBackgroundBrush" Color="#55B86F08" />
        <SolidColorBrush x:Key="DockPreviewBorderBrush" Color="#CCB86F08" />

        <!-- Microsoft Fluent UI System Icons (Regular, 20px), MIT licensed.
             Source: microsoft/fluentui-system-icons. These geometries map directly
             to the single, two-column, two-row, split-right, and four-cell presets. -->
