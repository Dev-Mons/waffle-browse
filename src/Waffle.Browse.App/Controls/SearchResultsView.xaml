<UserControl x:Class="Waffle.Browse.App.Controls.SearchResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource PrimaryTextBrush}"
             Background="{DynamicResource ShellHostBackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border x:Name="AvailabilityPanel"
                Grid.Row="0"
                Padding="8,5"
                Background="{DynamicResource ToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,0,0,1"
                Visibility="Collapsed">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="다시 확인"
                            Margin="6,0,0,0"
                            Click="OnRetryClick" />
                </StackPanel>
                <TextBlock x:Name="AvailabilityText"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <ListView x:Name="ResultsList"
                  Grid.Row="1"
                  Background="{DynamicResource ShellHostBackgroundBrush}"
                  Foreground="{DynamicResource PrimaryTextBrush}"
                  BorderThickness="0"
                  MouseDoubleClick="OnResultDoubleClick"
                  PreviewMouseRightButtonDown="OnResultPreviewMouseRightButtonDown"
                  KeyDown="OnResultKeyDown"
                  ScrollViewer.CanContentScroll="True"
                  VirtualizingPanel.IsVirtualizing="True"
                  VirtualizingPanel.VirtualizationMode="Recycling">
            <ListView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="열기" Click="OnOpenClick" />
                    <MenuItem Header="파일 위치 열기" Click="OnOpenLocationClick" />
                    <Separator />
                    <MenuItem Header="전체 경로 복사" Click="OnCopyPathClick" />
                </ContextMenu>
            </ListView.ContextMenu>
            <ListView.View>
                <GridView AllowsColumnReorder="True">
                    <GridViewColumn Width="260">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="이름" Tag="Name" Click="OnColumnHeaderClick" />
                        </GridViewColumn.Header>
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Left"
                                               Width="20"
                                               Margin="2,0,4,0"
                                               FontFamily="Segoe MDL2 Assets">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#xE8A5;" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Kind}" Value="Folder">
                                                        <Setter Property="Text" Value="&#xE8B7;" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                </DockPanel>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="420"
                                    DisplayMemberBinding="{Binding ParentPath}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="경로" Tag="Path" Click="OnColumnHeaderClick" />
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <GridViewColumn Width="150"
                                    DisplayMemberBinding="{Binding ModifiedAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="수정한 날짜" Tag="Modified" Click="OnColumnHeaderClick" />
                        </GridViewColumn.Header>
                    </GridViewColumn>
                    <GridViewColumn Width="110"
                                    DisplayMemberBinding="{Binding Size, StringFormat={}{0:N0}}">
                        <GridViewColumn.Header>
                            <GridViewColumnHeader Content="크기" Tag="Size" Click="OnColumnHeaderClick" />
                        </GridViewColumn.Header>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <Border Grid.Row="2"
                Padding="8,4"
                Background="{DynamicResource ToolbarBackgroundBrush}"
                BorderBrush="{DynamicResource PanelBorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock x:Name="ResultStatusText"
                       Foreground="{DynamicResource SubtleTextBrush}" />
        </Border>
    </Grid>
</UserControl>
