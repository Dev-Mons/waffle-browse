<UserControl x:Class="Waffle.Browse.App.Controls.ExplorerPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Foreground="{DynamicResource PrimaryTextBrush}">
    <Border x:Name="RootBorder"
            Margin="0"
            Background="{DynamicResource PanelBackgroundBrush}"
            BorderBrush="{DynamicResource PanelBorderBrush}"
            BorderThickness="2">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0"
                       Background="{DynamicResource ToolbarBackgroundBrush}"
                       LastChildFill="True"
                       MinHeight="28">
                <ListBox x:Name="TabsListBox"
                          AutomationProperties.AutomationId="TabsListBox"
                          BorderThickness="0"
                          Background="Transparent"
                          Focusable="False"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                          SelectionChanged="OnTabSelectionChanged"
                          PreviewMouseLeftButtonDown="OnTabMouseLeftButtonDown"
                          PreviewMouseMove="OnTabPreviewMouseMove">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="{x:Type ListBoxItem}">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
                            <Setter Property="Focusable" Value="False" />
                            <Setter Property="Padding" Value="0" />
                            <EventSetter Event="PreviewMouseDown"
                                         Handler="OnTabPreviewMouseDown" />
                            <EventSetter Event="PreviewMouseRightButtonDown"
                                          Handler="OnTabPreviewMouseRightButtonDown" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource TabHoverBackgroundBrush}" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource TabSelectedBackgroundBrush}" />
                                    <Setter Property="Foreground" Value="{DynamicResource TabSelectedForegroundBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <DockPanel MinWidth="92"
                                       MaxWidth="180"
                                       LastChildFill="True">
                                <DockPanel.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="탭 닫기"
                                                  Click="OnCloseTabMenuItemClick" />
                                        <MenuItem Header="열기"
                                                  Click="OnOpenTabMenuItemClick" />
                                    </ContextMenu>
                                </DockPanel.ContextMenu>
                                <TextBlock DockPanel.Dock="Left"
                                           Width="16"
                                           Margin="6,0,0,0"
                                           VerticalAlignment="Center"
                                           FontFamily="Segoe MDL2 Assets"
                                           Foreground="{DynamicResource SubtleTextBrush}"
                                           Text="&#xE8B7;" />
                                <TextBlock Text="{Binding Title}"
                                           Margin="6,0"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis" />
                            </DockPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <DockPanel Grid.Row="1"
                       Margin="6,2">
                <Button DockPanel.Dock="Left"
                        Style="{StaticResource NavButtonStyle}"
                        AutomationProperties.AutomationId="BackButton"
                        Content="&#xE72B;"
                        ToolTip="Back"
                        Click="OnBackClick" />
                <Button DockPanel.Dock="Left"
                        Style="{StaticResource NavButtonStyle}"
                        AutomationProperties.AutomationId="ForwardButton"
                        Content="&#xE72A;"
                        ToolTip="Forward"
                        Click="OnForwardClick" />
                <Button DockPanel.Dock="Left"
                        Style="{StaticResource NavButtonStyle}"
                        AutomationProperties.AutomationId="UpButton"
                        Content="&#xE74A;"
                        ToolTip="Parent folder"
                        Click="OnUpClick" />
                <TextBox x:Name="AddressBox"
                         AutomationProperties.AutomationId="AddressBox"
                         Margin="6,0,0,0"
                         VerticalContentAlignment="Center"
                         KeyDown="OnAddressKeyDown" />
            </DockPanel>

            <Grid x:Name="ShellHostArea"
                  AutomationProperties.AutomationId="ShellHostArea"
                  Grid.Row="2"
                  AllowDrop="True"
                  Background="{DynamicResource ShellHostBackgroundBrush}"
                  DragEnter="OnPanelDragEnter"
                  DragLeave="OnPanelDragLeave"
                  DragOver="OnPanelDragOver"
                  Drop="OnPanelDrop">
                <ContentControl x:Name="ShellHostContainer"
                                AutomationProperties.AutomationId="ShellHostContainer" />
            </Grid>
        </Grid>
    </Border>
</UserControl>
